{
  "name": "creator-intel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:push": "pnpm --filter web db:push",
    "db:studio": "pnpm --filter web db:studio",
    "ml:dev": "cd apps/ml && ./.venv/bin/uvicorn main:app --reload --port 8000",
    "webhook:register": "pnpm tsx scripts/register-helius-webhook.ts",
    "holders:backfill": "pnpm tsx scripts/backfill-holders.ts"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  }
}
